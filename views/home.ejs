<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>~/workspace/todo-list</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Import font Fira Code untuk nuansa terminal */
        @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600;700&display=swap');
        .font-mono { font-family: 'Fira Code', monospace; }
        
        /* Custom scrollbar untuk efek retro */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #1e1e2e; }
        ::-webkit-scrollbar-thumb { background: #313244; }
        ::-webkit-scrollbar-thumb:hover { background: #cba6f7; }
    </style>
</head>

<body class="bg-[#1e1e2e] text-[#cdd6f4] min-h-screen font-mono p-4 md:p-8 selection:bg-[#cba6f7] selection:text-[#1e1e2e]">

    <div class="max-w-5xl mx-auto">

        <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4 border-b border-[#313244] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[#cba6f7]">~/workspace</h1>
            </div>
            
            <div class="flex gap-3 w-full md:w-auto">
                <button
                    class="flex-1 md:flex-none px-5 py-2.5 bg-[#181825] hover:bg-[#313244] border border-[#313244] text-[#89b4fa] text-sm font-bold transition-colors shadow-[0_0_10px_rgba(137,180,250,0.1)]">
                    [ FILTER ]
                </button>
                <button onclick="logout()"
                    class="flex-1 md:flex-none px-5 py-2.5 bg-[#181825] hover:bg-[#f38ba8]/20 border border-[#313244] hover:border-[#f38ba8] text-[#f38ba8] text-sm font-bold transition-colors flex justify-center items-center gap-2">
                    <span>[ LOGOUT ]</span>
                </button>
            </div>
        </header>

        <form id="form-todo"
            class="flex flex-col md:flex-row gap-0 mb-10 bg-[#181825] border border-[#313244] shadow-[0_0_15px_rgba(0,0,0,0.3)] focus-within:border-[#cba6f7] transition-colors">
            
            <div class="flex items-center pl-4 text-[#cba6f7] font-bold">
                >
            </div>
            
            <input type="text" name="task" id="input-task" autocomplete="off"
                class="flex-1 px-3 py-4 bg-transparent text-[#cdd6f4] placeholder-[#6c7086] focus:outline-none text-base"
                placeholder="Apa yang ingin anda kerjakan?" required>
                
            <button type="submit"
                class="active:scale-95 transition-all bg-[#cba6f7]/10 hover:bg-[#cba6f7] border-l border-[#313244] text-[#cba6f7] hover:text-[#1e1e2e] font-bold px-8 py-4 transition-colors">
                EXECUTE
            </button>
        </form>

        <div id="card-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 items-stretch">
        </div>

    </div>

    <script>
        async function getTodos() {
            const cardContainer = document.getElementById('card-container')
            const result = await fetch('/api/todos')
            const todos = await result.json()

            const formatter = Intl.DateTimeFormat('id-ID', {
                day: 'numeric',
                month: 'short',
                year: 'numeric'
            })

            console.table(todos.payload)

            const userTasks = todos.payload
            
            cardContainer.innerHTML = userTasks.length > 0 ? userTasks.map((tasks, index) => `
            <div data-id="${tasks.id}" class="${tasks.is_completed ? 'bg-[#11111b] border-[#181825] opacity-60' : 'bg-[#181825] hover:border-[#cba6f7] border-[#313244] shadow-[0_4px_15px_rgba(0,0,0,0.2)]'}  border p-6 transition-all duration-200 group flex flex-col justify-between h-full ">
                <div>
                    <div class="flex justify-between items-start mb-4">
                        <span class="px-2.5 py-1 bg-[#89b4fa]/10 text-[#89b4fa] text-xs font-bold border border-[#89b4fa]/30">
                            #${index + 1}
                        </span>
                        <button onclick="deleteTaskHandler(${tasks.id}, ${tasks.is_completed})" class="hover:scale-110 transition-all text-[#6c7086] hover:text-[#f38ba8] opacity-0 group-hover:opacity-100 transition-opacity">
                            <svg class="pointer-events-none w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </div>
                    <p class="font-medium text-lg leading-relaxed mb-4 ${tasks.is_completed ? 'text-[#6c7086] line-through' : 'text-[#cdd6f4]'}">${tasks.task}</p>
          
                </div>
                
                <div class="flex items-center justify-between pt-4 border-t border-[#313244] mt-auto">
                    <p class="text-xs text-[#a6adc8] font-medium">${formatter.format(new Date(tasks.created_at))}</p>
                    <button ${tasks.is_completed ? `onclick="toggleTask(${tasks.id}, false)"` : `onclick="toggleTask(${tasks.id}, true)"`} class="hover:scale-110 w-6 h-6 border-2 flex items-center justify-center ${tasks.is_completed ? 'border-[#a6e3a1] bg-[#a6e3a1]' : 'border-[#6c7086] hover:border-[#a6e3a1] hover:bg-[#a6e3a1]/20 transition-colors'}">
                        ${tasks.is_completed
                    ? `<svg class="pointer-events-none w-4 h-4 text-[#1e1e2e]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                            </svg>`
                    : ''
                }        
                        
                    </button>

                </div>
            </div>
            
            `).join('') 
            : `
            <div class="col-span-1 md:col-span-2 lg:col-span-3 flex flex-col items-center justify-center py-16 px-4 border-2 border-dashed border-[#313244] bg-[#181825]/30 mt-4 transition-all">
                <div class="text-[#6c7086] text-5xl mb-4 font-bold tracking-widest">
                    (>_<)
                </div>
                <h3 class="text-[#cba6f7] font-bold text-xl mb-2">~/workspace kosong</h3>
                <p class="text-[#a6adc8] text-sm text-center max-w-md">
                    Belum ada task yang dieksekusi hari ini. Silakan input perintah di atas untuk memulai.
                </p>
            </div>
            `;
        }

        getTodos()

        const formTodo = document.getElementById('form-todo')
        const inputTask = document.getElementById('input-task')

        formTodo.addEventListener('submit', async (e) => {
            e.preventDefault()
            const task = inputTask.value.trim()

            if (!task) return

            try {

                const res = await fetch('/api/todos', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ task: task })
                })

                inputTask.value = ""
                getTodos()
            } catch (err) {
                console.error("error: ", err)
            }

        })

        async function logout() {
            playDeleteSound()
            const yakin = confirm('apakah anda yakin ingin logout?')
            if(!yakin) return
            await fetch('/logout', {
                method: 'POST',
            })
            window.location.href = '/login'
        }

        function deleteTaskHandler(taskId, isCompleted) {
            console.log(isCompleted)
            if (!isCompleted) {
                const yakin = confirm("Tugas belum selesai. Yakin ingin Hapus?")
                if (!yakin) return
            }


            execDeleteTask(taskId)
        }

        async function execDeleteTask(taskId) {
            playDeleteSound()
            const res = await fetch(`/api/todos/${taskId}`, {
                method: 'DELETE'
            })
            getTodos()
        }

        async function toggleTask(taskId, request) {
            const card = document.querySelector(`[data-id="${taskId}"]`)
            card.classList.add('opacity-50', 'scale-90', 'transition-all', 'duration-200')

            await new Promise(resolve => setTimeout(resolve, 200))
            if (request) {
                playCheckSound()
            } else {
                playUncheckSound()
            }

            await fetch(`/api/todos/${taskId}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 'taskId': taskId, 'is_completed': request })
            })

            getTodos()
        }

        function playCheckSound() {
            const ctx = new AudioContext()
            const oscillator = ctx.createOscillator()
            const gainNode = ctx.createGain()

            oscillator.connect(gainNode)
            gainNode.connect(ctx.destination)

            oscillator.frequency.setValueAtTime(600, ctx.currentTime)
            oscillator.frequency.setValueAtTime(900, ctx.currentTime + 0.1)

            gainNode.gain.setValueAtTime(0.3, ctx.currentTime)
            gainNode.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3)

            oscillator.start(ctx.currentTime)
            oscillator.stop(ctx.currentTime + 0.3)
        }

        function playUncheckSound() {
            const ctx = new AudioContext()
            const oscillator = ctx.createOscillator()
            const gainNode = ctx.createGain()

            oscillator.connect(gainNode)
            gainNode.connect(ctx.destination)

            oscillator.type = 'sine'
            oscillator.frequency.setValueAtTime(500, ctx.currentTime)
            oscillator.frequency.linearRampToValueAtTime(300, ctx.currentTime + 0.3)

            gainNode.gain.setValueAtTime(0.2, ctx.currentTime)
            gainNode.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3)

            oscillator.start(ctx.currentTime)
            oscillator.stop(ctx.currentTime + 0.3)
        }

        function playDeleteSound() {
            const ctx = new AudioContext()
            const oscillator = ctx.createOscillator()
            const gainNode = ctx.createGain()

            oscillator.connect(gainNode)
            gainNode.connect(ctx.destination)

            oscillator.type = 'sine'
            oscillator.frequency.setValueAtTime(150, ctx.currentTime)
            oscillator.frequency.exponentialRampToValueAtTime(40, ctx.currentTime + 0.2)

            gainNode.gain.setValueAtTime(0.5, ctx.currentTime)
            gainNode.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.2)

            oscillator.start(ctx.currentTime)
            oscillator.stop(ctx.currentTime + 0.2)
        }
    </script>

</body>

</html>